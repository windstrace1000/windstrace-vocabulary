{
  "name": "vocabulary-master",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:cf": "npx wrangler pages dev dist --d1=DB",
    "db:create": "npx wrangler d1 create windstrace-vocabulary-DB",
    "db:init": "npx wrangler d1 execute windstrace-vocabulary-DB --file=schema.sql",
    "db:init:local": "npx wrangler d1 execute windstrace-vocabulary-DB --local --file=schema.sql",
    "deploy": "npm run build && npx wrangler pages deploy dist"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.4.2",
    "wrangler": "^3.60.0"
  }
}
